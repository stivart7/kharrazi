# ============================================
# Kharrazi - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://kharrazi_user:kharrazi_pass@localhost:5432/kharrazi_db?schema=public"

# ── API ───────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_HOST=localhost

# ── JWT ───────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME="Kharrazi"

# ── Email (Nodemailer / SMTP) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Kharrazi <noreply@example.com>"

# ── Rate Limiting ──────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Cors ──────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Redis (optional, for session/rate-limit) ──
REDIS_URL=redis://localhost:6379

# ── Storage (for car images) ──────────────────
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
